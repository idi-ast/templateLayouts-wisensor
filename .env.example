# ============================================
# TEMPLATE WISENSOR - Variables de Entorno
# ============================================
# Copia este archivo a .env y configura los valores
# cp .env.example .env

# --------------------------------------------
# Configuración de empresa
# --------------------------------------------
VITE_COMPANY_NAME="AST Networks Technology"
VITE_COMPANY_ADDRESS="Camino El Tepual Km 1, Puerto Montt, Chile"
VITE_COMPANY_PHONE="+56 2 3366 3478"
VITE_COMPANY_EMAIL="ventas@ast.cl"
VITE_COMPANY_WEBSITE="www.ast.cl"

# --------------------------------------------
# Configuración de la aplicación
# --------------------------------------------
VITE_APP_PROVEEDOR="WISENSOR"
VITE_APP_NAME="NombreApp"
VITE_APP_CODE="WIS-TEMP-001" # Codigo de la aplicación
VITE_APP_ENV="development" # development, production, staging, etc
VITE_APP_DEFAULT_THEME="dark"
# --------------------------------------------
# Configuración del servidor de desarrollo
# --------------------------------------------
VITE_SERVER_PORT=3001
VITE_SERVER_HOST=true
VITE_SERVER_ALLOW_CORS=disasters.iotlink.cl # Para desarrollo local, permite CORS desde este dominio (puede ser un wildcard o localhost)

# --------------------------------------------
# Configuración de la API escencial para la arquitectura de la aplicación, no modificable
# Conexion al backend de autenticación, gestión de usuarios, roles y permisos, etc. Es la base para el funcionamiento del sistema.
# Se reserva el uso de /api : api nativa de la aplicación
# --------------------------------------------
VITE_API_BASE_URL="/api"
VITE_API_VERSION="v1"
VITE_API_TIMEOUT=30000
# IP real del backend (usada por el proxy Vite, nunca expuesta al navegador)
VITE_API_PROXY_TARGET="http://10.20.7.97:8000" 

# --------------------------------------------
# Configuración de la API SYSTEM backend del sistema personalizado
# Conexion agnóstico al sistema, backend de la aplicación que se creará
# Se reserva el uso de /api-system : api personalizada del sistema, con su propia lógica, endpoints, etc. Es la base para el funcionamiento del sistema.
# ------------------------------------------
VITE_API_SYSTEM_URL="/api-system" 
# IP real del backend del sistema (usada por el proxy Vite, nunca expuesta al navegador)
VITE_API_SYSTEM_PROXY_TARGET="http://10.20.7.97:8000"

# --------------------------------------------
# Configuración del cliente Socket.IO
# --------------------------------------------
VITE_SOCKET_URL="http://localhost:3001"

# --------------------------------------------
# Autenticación
# --------------------------------------------
VITE_AUTH_URL="https://dominio-expuesto.cl"
VITE_AUTH_CALLBACK_URL="/"
VITE_AUTH_TOKEN_KEY="access_token"
VITE_AUTH_REFRESH_TOKEN_KEY="refresh_token"

# --------------------------------------------
# Servicios externos
# --------------------------------------------
VITE_MAPBOX_NAME_TOKEN="nombre_token"
VITE_MAPBOX_TOKEN="tu_mapbox_token_aqui"
